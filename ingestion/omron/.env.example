# Copy this file to .env and fill in your Omron Connect credentials.
# .env is gitignored and must never be committed.
OMRON_EMAIL=
OMRON_PASSWORD=

# Optional overrides:
# Your Omron Connect account country (default US)
# OMRON_COUNTRY=US
# Number of days back to pull (default 7)
# DAYS_BACK=7
# Earliest measurement date to keep — filters out previous-owner readings (YYYY-MM-DD)
# OMRON_EARLIEST_DATE=2025-01-01
# Where the auth token is cached (default ~/.omron_tokens.json)
# OMRON_TOKENSTORE=~/.omron_tokens.json
# API server — override only if outside North America
# OMRON_SERVER=https://vlt-mobile-api.prd.us.ohiomron.com/prd
